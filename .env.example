# Faith Harbor OS environment configuration
#
# Copy this file to ".env" and fill in the values for your
# environment. Never commit the real ".env" file.

# ---- Core ----
# Use "production" on the cPanel/WHM server.
NODE_ENV=production

# Port the Node process listens on. On cPanel with Passenger this
# is set automatically; a local or PM2 run uses this value.
PORT=3000

APP_NAME=Faith Harbor OS

# Optional. When omitted the version comes from package.json.
# APP_VERSION=

# Optional external database URL. The app defaults to a local
# SQLite file at data/faith-harbor.db when this is empty.
DATABASE_URL=

# ---- Authentication (REQUIRED in production) ----
# The single administrator login. In production the app refuses to
# start unless ADMIN_EMAIL and one of the password values are set.
ADMIN_EMAIL=
# Either set a plaintext password (simplest) ...
ADMIN_PASSWORD=
# ... or a scrypt hash generated with: npm run hash-password "your-pass"
# (if the hash is set it takes precedence over ADMIN_PASSWORD)
ADMIN_PASSWORD_HASH=
# Session lifetime in hours (default 12).
SESSION_TTL_HOURS=12
# Optional cross-origin allowlist. Leave empty for same-origin only.
CORS_ORIGIN=

# ---- Email delivery (optional) ----
# The "from" address on outgoing email. For best deliverability over
# SMTP, use the same mailbox you authenticate with below.
EMAIL_FROM=

# Option 1: SMTP (e.g. a cPanel mailbox). When SMTP_HOST, SMTP_USER,
# and SMTP_PASSWORD are all set, email sends through this server.
# SMTP takes precedence over the HTTP API below.
SMTP_HOST=
# 465 = implicit SSL/TLS (recommended for cPanel). 587 = STARTTLS.
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# Leave empty to derive from the port (true on 465). Set "false" for 587.
SMTP_SECURE=
# Verify the mail server's TLS certificate. Default is on. Set "false"
# only for a self-signed/unverifiable cert (e.g. a local mail server).
SMTP_REJECT_UNAUTHORIZED=

# Option 2: a JSON email API (e.g. Resend: https://api.resend.com/emails).
# Used only when SMTP is not configured.
EMAIL_API_URL=
EMAIL_API_KEY=

# ---- Automation ----
# How often (in minutes) the automation engine scans for time-based
# work such as overdue invoices, preparing draft reminders for your
# review. Drafts always wait for your approval before anything sends.
# Set to 0 to turn off periodic scanning. Default is 360 (6 hours).
AUTOMATION_SCAN_INTERVAL_MINUTES=360
# Days without an update before an open lead is treated as quiet and a
# follow-up draft is prepared. Default is 7.
AUTOMATION_LEAD_QUIET_DAYS=7
# Days without an update before an active project is treated as stalled
# and a check-in draft is prepared. Default is 14.
AUTOMATION_PROJECT_STALLED_DAYS=14

# ---- AI providers (all optional) ----
# The app runs without these; AI features stay disabled until set.
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
BLACKBOX_API_KEY=

# ---- WHM / cPanel hosting (optional, read-only) ----
# When set, the Hosting department shows live server load and
# accounts from WHM. Leave empty to run without a live connection.
# The API token needs only read access; the OS never suspends or
# terminates accounts.
WHM_HOST=
WHM_API_TOKEN=
WHM_USER=root
WHM_PORT=2087
