# Faith Harbor OS environment configuration
#
# Copy this file to ".env" and fill in the values for your
# environment. Never commit the real ".env" file.

# ---- Core ----
# Use "production" on the cPanel/WHM server.
NODE_ENV=production

# Port the Node process listens on. On cPanel with Passenger this
# is set automatically; a local or PM2 run uses this value.
PORT=3000

APP_NAME=Faith Harbor OS

# Optional. When omitted the version comes from package.json.
# APP_VERSION=

# Optional external database URL. The app defaults to a local
# SQLite file at data/faith-harbor.db when this is empty.
DATABASE_URL=

# ---- AI providers (all optional) ----
# The app runs without these; AI features stay disabled until set.
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
BLACKBOX_API_KEY=

# ---- WHM / cPanel hosting (optional, read-only) ----
# When set, the Hosting department shows live server load and
# accounts from WHM. Leave empty to run without a live connection.
# The API token needs only read access; the OS never suspends or
# terminates accounts.
WHM_HOST=
WHM_API_TOKEN=
WHM_USER=root
WHM_PORT=2087
